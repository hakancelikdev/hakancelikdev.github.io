---
import Layout from '~/layouts/PageLayout.astro';
import JsonLd from '~/components/common/JsonLd.astro';

import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getPermalink } from '~/utils/permalinks';
import profileHeroImg from '~/assets/images/profile-hero.jpg';

// Build-time stats helpers
import fs from 'node:fs';
import path from 'node:path';

const sleep = (ms: number) => new Promise((r) => setTimeout(r, ms));

// Cache file: stores fetched stats for 1 hour to avoid rate-limiting pypistats in dev mode
const CACHE_FILE = path.resolve('./src/data/_stats-cache.json');
const CACHE_TTL_MS = 60 * 60 * 1000; // 1 hour

interface StatsCache {
  fetchedAt: number;
  github: Record<string, string>;
  pypi: Record<string, string>;
}

function readCache(): StatsCache | null {
  try {
    const raw = fs.readFileSync(CACHE_FILE, 'utf-8');
    const cache: StatsCache = JSON.parse(raw);
    if (Date.now() - cache.fetchedAt < CACHE_TTL_MS) return cache;
  } catch { /* no cache or invalid */ }
  return null;
}

function writeCache(cache: StatsCache) {
  try { fs.writeFileSync(CACHE_FILE, JSON.stringify(cache, null, 2)); } catch { /* ignore write errors */ }
}

async function githubStars(repo: string): Promise<string> {
  try {
    const res = await fetch(`https://api.github.com/repos/${repo}`, {
      headers: { Accept: 'application/vnd.github.v3+json' },
    });
    if (!res.ok) return '';
    const data = await res.json();
    const n: number = data.stargazers_count;
    return n >= 1000 ? `${(n / 1000).toFixed(1)}k` : String(n);
  } catch {
    return '';
  }
}

async function pypiDownloads(pkg: string): Promise<string> {
  for (let attempt = 0; attempt < 3; attempt++) {
    try {
      if (attempt > 0) await sleep(3000 * attempt);
      const res = await fetch(`https://pypistats.org/api/packages/${pkg}/recent?period=month`);
      if (res.status === 429) continue;
      if (!res.ok) return '';
      const data = await res.json();
      const n: number = data.data.last_month;
      if (n >= 1_000_000) return `${(n / 1_000_000).toFixed(1)}M/ay`;
      if (n >= 1_000) return `${Math.round(n / 1000)}k/ay`;
      return `${n}/ay`;
    } catch {
      return '';
    }
  }
  return '';
}

function badge(icon: string, value: string, title: string) {
  if (!value || value === '0') return '';
  return `<span title="${title}" class="inline-flex items-center gap-1 text-xs font-medium bg-orange-50 dark:bg-orange-950/30 text-orange-700 dark:text-orange-300 px-2 py-0.5 rounded-sm">${icon} ${value}</span>`;
}

function statsBadges(stars: string, downloads: string) {
  const b = [badge('★', stars, 'GitHub Stars'), badge('↓', downloads, 'PyPI Downloads')]
    .filter(Boolean)
    .join(' ');
  return b ? `<span class="flex gap-1.5 mt-2 flex-wrap">${b}</span>` : '';
}

// Check cache first — avoids hitting rate limits during dev reloads
const cached = readCache();

let unimportStars: string, unexportStars: string, pydbmStars: string, defineifStars: string;
let vakitStars: string, siteSeekerStars: string, meldStars: string;
let unimportDl: string, unexportDl: string, pydbmDl: string, defineifDl: string;

if (cached) {
  ({ unimportStars = '', unexportStars = '', pydbmStars = '', defineifStars = '',
     vakitStars = '', siteSeekerStars = '', meldStars = '' } = cached.github as Record<string, string>);
  unimportDl  = cached.pypi['unimport']      ?? '';
  unexportDl  = cached.pypi['unexport']      ?? '';
  pydbmDl     = cached.pypi['pythonic-dbm']  ?? '';
  defineifDl  = cached.pypi['defineif']      ?? '';
} else {
  // GitHub: parallel (different host, no rate limit issue)
  [unimportStars, unexportStars, pydbmStars, defineifStars,
   vakitStars, siteSeekerStars, meldStars] = await Promise.all([
    githubStars('hakancelikdev/unimport'),
    githubStars('hakancelikdev/unexport'),
    githubStars('hakancelikdev/pydbm'),
    githubStars('hakancelikdev/defineif'),
    githubStars('hakancelikdev/vakit'),
    githubStars('hakancelikdev/SiteSeeker'),
    githubStars('hakancelikdev/meld'),
  ]);

  // PyPI: parallel with retry — faster than sequential 4s delays
  [unimportDl, unexportDl, pydbmDl, defineifDl] = await Promise.all([
    pypiDownloads('unimport'),
    pypiDownloads('unexport'),
    pypiDownloads('pythonic-dbm'),
    pypiDownloads('defineif'),
  ]);

  writeCache({
    fetchedAt: Date.now(),
    github: { unimportStars, unexportStars, pydbmStars, defineifStars,
              vakitStars, siteSeekerStars, meldStars },
    pypi: { unimport: unimportDl, unexport: unexportDl, 'pythonic-dbm': pydbmDl, defineif: defineifDl },
  });
}

const metadata = {
  title: 'Hakan Çelik — Software Engineer',
  ignoreTitleTemplate: true,
  description: 'Hakan Çelik — Software Engineer. Python araçları, iOS/macOS uygulamaları ve açık kaynak yazılım üzerine Türkçe blog.',
  keywords: 'Hakan Çelik, Python, yazılım mühendisi, software engineer, açık kaynak, unimport, unexport, pydbm, iOS, macOS, Django, Go, Trendyol',
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Hakan Çelik',
  url: 'https://hakancelik.dev',
  description: metadata.description,
  inLanguage: 'tr-TR',
  author: {
    '@type': 'Person',
    name: 'Hakan Çelik',
    url: 'https://hakancelik.dev',
  },
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://hakancelik.dev/blog?q={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Hakan Çelik',
  url: 'https://hakancelik.dev',
  image: 'https://hakancelik.dev/hakancelik.jpg',
  jobTitle: 'Software Engineer',
  worksFor: {
    '@type': 'Organization',
    name: 'Trendyol Go',
  },
  sameAs: [
    'https://twitter.com/hakancelikdev',
    'https://github.com/hakancelikdev',
    'https://www.linkedin.com/in/hakancelikdev',
  ],
  knowsAbout: ['Python', 'iOS', 'macOS', 'Django', 'Go', 'OpenCV', 'Açık Kaynak Yazılım'],
};
---

<Layout metadata={metadata}>
  <Fragment slot="head">
    <JsonLd schema={[websiteSchema, personSchema]} />
  </Fragment>

  <!-- Hero: Split layout -->
  <section id="hero" class="relative not-prose md:-mt-[76px] overflow-hidden">
    <!-- Background -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="hero-grid absolute inset-0"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-page to-page opacity-60"></div>
    </div>

    <div class="pt-0 md:pt-[76px]"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-0 lg:gap-16 items-center py-16 md:py-24 lg:py-32">

        <!-- Left: Text -->
        <div class="order-2 lg:order-1 hero-item" style="--delay: 0.1s">
          <div class="mb-10">
            <span class="inline-flex items-center gap-3 font-mono text-[10px] tracking-[0.2em] uppercase text-primary border-l-2 border-primary bg-primary/[0.04] px-4 py-2">
              <span class="w-1.5 h-1.5 rounded-full bg-primary inline-block shrink-0 animate-pulse"></span>
              Software Engineer & Open Source Enthusiast
            </span>
          </div>

          <h1
            class="font-heading text-5xl sm:text-6xl md:text-7xl lg:text-[5.5rem] font-bold leading-[0.95] tracking-tighter mb-8 dark:text-white"
            style="font-variation-settings: 'opsz' 144, 'wght' 800;"
          >
            Merhaba, ben <span class="text-accent dark:text-white">Hakan Çelik</span>
          </h1>

          <div class="w-16 h-0.5 bg-primary/40 mb-8"></div>

          <p class="text-xl md:text-2xl text-muted leading-relaxed font-light italic serif mb-10 max-w-lg">
            Python araçları, iOS/macOS uygulamaları ve açık kaynak üzerine odaklanan bir <span class="font-semibold">yazılım mühendisi</span>.
            Trendyol Go'da geliştirici olarak çalışıyorum.
          </p>

          <div class="flex flex-wrap gap-4">
            <a href="#projects" class="btn btn-primary rounded-none border-2 hover:bg-primary hover:text-white transition-all duration-300 inline-flex items-center gap-2">
              Projeleri Gör
            </a>
            <a href={getPermalink('/blog')} class="btn rounded-none border-2 hover:bg-primary hover:text-white transition-all duration-300">
              Blog
            </a>
          </div>
        </div>

        <!-- Right: Photo -->
        <div class="order-1 lg:order-2 mb-12 lg:mb-0 hero-item" style="--delay: 0.3s">
          <div class="relative">
            <div class="absolute -inset-3 border-2 border-primary/10 -z-10 hidden lg:block"></div>
            <div class="absolute -inset-6 border border-primary/5 -z-20 hidden lg:block"></div>
            <img
              src={profileHeroImg.src}
              alt="Hakan Çelik"
              width="1920"
              height="1440"
              class="w-full shadow-2xl shadow-primary/10"
              loading="eager"
            />
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Uygulamalar -->
  <Features2
    id="projects"
    title="Uygulamalar"
    subtitle="iOS ve macOS için geliştirdiğim uygulamalar."
    tagline="Apps"
    items={[
      {
        title: 'Vakit',
        description: `Namaz vakitleri, Kuran okuma, kıble, zikir sayacı ve daha fazlası — hepsi tek uygulamada. Gizlilik odaklı: konum verilerin cihazında kalır, hesap gerekmez, internet bağlantısı gerekmez. Ücretsiz ve reklamsız.${statsBadges(vakitStars, '')} <br /><br />
        <a href="https://apps.apple.com/app/id6748356813" target="_blank" class="text-primary hover:underline">İndir (App Store)</a>`,
        icon: 'tabler:moon-stars',
        callToAction: { text: 'vakit.hakancelik.dev', href: 'https://vakit.hakancelik.dev', target: '_blank' },
      },
      {
        title: 'SiteSeeker',
        description: `macOS için akıllı tarayıcı geçmişi ve yer imi arama. Tüm tarayıcılarını tek arayüzde ara.${statsBadges(siteSeekerStars, '')} <br /><br />
        <a href="https://github.com/hakancelikdev/SiteSeeker" target="_blank" class="text-primary hover:underline">Star on GitHub</a>`,
        icon: 'tabler:search',
        callToAction: { text: 'siteseeker.hakancelik.dev', href: 'https://siteseeker.hakancelik.dev', target: '_blank' },
      },
      {
        title: 'Meld',
        description: `Minimalist karo birleştirme bulmaca oyunu. Kaydır, birleştir, çöz.${statsBadges(meldStars, '')}`,
        icon: 'tabler:puzzle',
        callToAction: { text: 'meld.hakancelik.dev', href: 'https://meld.hakancelik.dev', target: '_blank' },
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-orange-50/30 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- Python Araçları -->
  <Features3
    title="Python Araçları"
    subtitle="Python geliştirici deneyimini iyileştiren açık kaynak araçlar."
    tagline="Open Source"
    columns={2}
    items={[
      {
        title: 'unimport',
        description: `Kullanılmayan import ifadelerini bulan ve kaldıran linter/formatter. pre-commit hook olarak kullanılabilir.${statsBadges(unimportStars, unimportDl)} <br /><br />
        <a href="https://github.com/hakancelikdev/unimport" target="_blank" class="text-primary hover:underline">Star on GitHub</a>`,
        icon: 'tabler:brand-python',
        callToAction: { text: 'unimport.hakancelik.dev', href: 'https://unimport.hakancelik.dev', target: '_blank' },
      },
      {
        title: 'unexport',
        description: `Python modüllerindeki __all__ listesini her zaman güncel tutan linter.${statsBadges(unexportStars, unexportDl)} <br /><br />
        <a href="https://github.com/hakancelikdev/unexport" target="_blank" class="text-primary hover:underline">Star on GitHub</a>`,
        icon: 'tabler:brand-python',
        callToAction: { text: 'unexport.hakancelik.dev', href: 'https://unexport.hakancelik.dev', target: '_blank' },
      },
      {
        title: 'pydbm',
        description: `Python'ın dahili dbm modülünü ORM benzeri bir arayüzle kullanan Pythonic wrapper.${statsBadges(pydbmStars, pydbmDl)} <br /><br />
        <a href="https://github.com/hakancelikdev/pydbm" target="_blank" class="text-primary hover:underline">Star on GitHub</a>`,
        icon: 'tabler:database',
        callToAction: { text: 'pydbm.hakancelik.dev', href: 'https://pydbm.hakancelik.dev', target: '_blank' },
      },
      {
        title: 'defineif',
        description: `Bir koşul doğruysa metodu tanımla decorator'u. Basit ama zarif.${statsBadges(defineifStars, defineifDl)} <br /><br />
        <a href="https://github.com/hakancelikdev/defineif" target="_blank" class="text-primary hover:underline">Star on GitHub</a>`,
        icon: 'tabler:code',
        callToAction: { text: 'defineif.hakancelik.dev', href: 'https://defineif.hakancelik.dev', target: '_blank' },
      },
    ]}
  />

  <!-- Blog -->
  <BlogLatestPosts
    id="blog"
    title="Son Yazılar"
    information="Python, Django, Git, OpenCV, Cloud ve daha fazlası üzerine Türkçe yazılar."
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-orange-50/30 dark:bg-transparent"></div>
    </Fragment>
  </BlogLatestPosts>

  <!-- CTA -->
  <CallToAction
    title="X, LinkedIn ve GitHub'da takipleşelim"
    subtitle="Yeni projeler, teknik notlar ve açık kaynak güncellemeleri için beni takip et."
    actions={[
      {
        variant: 'primary',
        text: 'github.com/hakancelikdev',
        href: 'https://github.com/hakancelikdev',
        target: '_blank',
        icon: 'tabler:brand-github',
      },
      {
        text: 'x.com/hakancelikdev',
        href: 'https://twitter.com/hakancelikdev',
        target: '_blank',
        icon: 'tabler:brand-x',
      },
      {
        text: 'linkedin.com/in/hakancelikdev',
        href: 'https://www.linkedin.com/in/hakancelikdev',
        target: '_blank',
        icon: 'tabler:brand-linkedin',
      },
    ]}
  />
</Layout>

<style>
  .serif {
    font-family: var(--aw-font-serif);
  }

  .hero-item {
    animation: heroRise 1.2s cubic-bezier(0.16, 1, 0.3, 1) var(--delay, 0s) both;
  }

  @keyframes heroRise {
    from {
      opacity: 0;
      transform: translateY(2rem) skewY(1deg);
    }
    to {
      opacity: 1;
      transform: translateY(0) skewY(0deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-item {
      animation: none;
    }
  }

  .hero-grid {
    background-image:
      radial-gradient(circle at 2px 2px, rgb(234 88 12 / 0.15) 1.5px, transparent 0);
    background-size: 48px 48px;
    mask-image: radial-gradient(ellipse 70% 70% at 0% 0%, black 10%, transparent 90%);
  }

  :global(.dark) .hero-grid {
    background-image:
      radial-gradient(circle at 2px 2px, rgb(251 146 60 / 0.12) 1.5px, transparent 0);
  }
</style>
