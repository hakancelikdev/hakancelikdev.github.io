async function pypiMonthly(pkg: string): Promise<string> {
  for (let attempt = 0; attempt < 3; attempt++) {
    try {
      if (attempt > 0) await new Promise((r) => setTimeout(r, 3000 * attempt));
      const res = await fetch(`https://pypistats.org/api/packages/${pkg}/recent?period=month`);
      if (res.status === 429) continue;
      if (!res.ok) return '';
      const data = await res.json();
      const n: number = data.data.last_month;
      if (n >= 1_000_000) return `${(n / 1_000_000).toFixed(1)}M/mo`;
      if (n >= 1_000) return `${Math.round(n / 1000)}K/mo`;
      return `${n}/mo`;
    } catch {
      return '';
    }
  }
  return '';
}

const unimportMonthly = await pypiMonthly('unimport');

