---
import Layout from '~/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';
import { findAllSeries } from '~/utils/blog';
import { getPermalink } from '~/utils/permalinks';

export const prerender = true;

const allSeries = await findAllSeries('tr');

const metadata = {
  title: 'Seriler',
  description: 'Konulara göre gruplandırılmış yazı serileri — OpenCV, Python, Sass ve daha fazlası.',
  openGraph: { type: 'website' },
};
---

<Layout metadata={metadata}>
  <section class="px-6 sm:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-4xl">

    <header class="mb-10 md:mb-14 text-center">
      <h1 class="text-4xl md:text-5xl font-bold leading-tighter tracking-tighter font-heading">
        Seriler
      </h1>
      <p class="mt-3 text-xl text-muted dark:text-slate-400">
        Adım adım öğrenmek için konulara göre gruplanmış yazı serileri.
      </p>
    </header>

    {allSeries.length === 0 ? (
      <p class="text-center text-muted">Henüz bir seri yok.</p>
    ) : (
      <div class="grid gap-5 sm:grid-cols-2">
        {allSeries.map((s) => (
          <a
            href={getPermalink(s.firstPost.permalink, 'post')}
            class="group flex flex-col rounded-xl border dark:border-stone-700 overflow-hidden hover:border-primary dark:hover:border-primary transition-colors bg-white dark:bg-stone-900"
          >
            <div class="flex-1 p-5">
              <div class="flex items-start justify-between gap-3 mb-3">
                <div class="flex items-center gap-2">
                  <Icon name="tabler:list-numbers" class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" />
                  <h2 class="text-base font-bold leading-snug group-hover:text-primary transition-colors">
                    {s.name}
                  </h2>
                </div>
                <span class="flex-shrink-0 text-xs font-medium bg-primary/10 text-primary px-2 py-0.5 rounded-full">
                  {s.count} yazı
                </span>
              </div>

              {s.category && (
                <span class="inline-block text-xs text-muted dark:text-stone-400 bg-gray-100 dark:bg-stone-800 px-2 py-0.5 rounded mb-3">
                  {s.category.title}
                </span>
              )}

              <p class="text-sm text-muted dark:text-stone-400 line-clamp-2">
                {s.firstPost.excerpt}
              </p>
            </div>

            <div class="px-5 py-3 border-t dark:border-stone-700 bg-gray-50 dark:bg-stone-800/50 flex items-center justify-between">
              <span class="text-xs text-muted dark:text-stone-500">İlk yazıdan başla</span>
              <Icon name="tabler:arrow-right" class="w-4 h-4 text-primary group-hover:translate-x-0.5 transition-transform" />
            </div>
          </a>
        ))}
      </div>
    )}
  </section>
</Layout>
