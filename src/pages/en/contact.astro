---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Contact',
};
---

<Layout metadata={metadata}>
  <Hero tagline="Contact">
    <Fragment slot="title">
      Got an idea?<br />Let's talk.
    </Fragment>
    <Fragment slot="subtitle">
      Open source collaboration, technical questions, project proposals, or just saying hi
      — the fastest way is email or X DM.
    </Fragment>
  </Hero>

  <Features2
    title="Get in touch"
    subtitle="Response time is usually 1-2 days. For open source matters I prefer GitHub issues."
    items={[
      {
        title: 'E-mail',
        description: '<a href="mailto:hakancelikdev@gmail.com" class="text-primary hover:underline">hakancelikdev@gmail.com</a>',
        icon: 'tabler:mail',
      },
      {
        title: 'GitHub',
        description: '<a href="https://github.com/hakancelikdev" target="_blank" class="text-primary hover:underline">github.com/hakancelikdev</a>',
        icon: 'tabler:brand-github',
      },
      {
        title: 'Twitter / X',
        description: '<a href="https://twitter.com/hakancelikdev" target="_blank" class="text-primary hover:underline">@hakancelikdev</a>',
        icon: 'tabler:brand-x',
      },
      {
        title: 'LinkedIn',
        description: '<a href="https://www.linkedin.com/in/hakancelikdev" target="_blank" class="text-primary hover:underline">linkedin.com/in/hakancelikdev</a>',
        icon: 'tabler:brand-linkedin',
      },
      {
        title: 'Telegram',
        description: '<a href="https://t.me/hakancelikdev" target="_blank" class="text-primary hover:underline">@hakancelikdev</a>',
        icon: 'tabler:brand-telegram',
      },
    ]}
    columns={3}
  />
</Layout>
