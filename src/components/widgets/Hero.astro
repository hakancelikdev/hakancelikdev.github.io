---
import Image from '~/components/common/Image.astro';
import Button from '~/components/ui/Button.astro';

import type { Hero as Props } from '~/types';

const {
  title = await Astro.slots.render('title'),
  subtitle = await Astro.slots.render('subtitle'),
  tagline,

  content = await Astro.slots.render('content'),
  actions = await Astro.slots.render('actions'),
  image = await Astro.slots.render('image'),

  id,
  bg = await Astro.slots.render('bg'),
} = Astro.props;
---

<section class="relative md:-mt-[76px] not-prose overflow-hidden" {...id ? { id } : {}}>
  <!-- Background layer -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <slot name="bg">
      {bg ? <Fragment set:html={bg} /> : null}
    </slot>
  </div>

  <!-- Subtle grid pattern overlay -->
  <div
    class="absolute inset-0 pointer-events-none hero-grid"
    aria-hidden="true"
  ></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
    <div class="pt-0 md:pt-[76px] pointer-events-none"></div>
    <div class="py-16 md:py-24 lg:py-32">

      <!-- Tagline pill -->
      {tagline && (
        <div class="mb-8 hero-item" style="--delay: 0s">
          <span class="inline-flex items-center gap-2 font-mono text-xs tracking-widest uppercase text-primary border border-primary/30 bg-primary/[0.06] px-3 py-1.5 rounded-sm">
            <span class="w-1.5 h-1.5 rounded-full bg-primary inline-block shrink-0"></span>
            <span set:html={tagline} />
          </span>
        </div>
      )}

      <!-- Main heading -->
      {title && (
        <h1
          class="font-heading text-5xl sm:text-6xl md:text-7xl lg:text-[5.5rem] font-bold leading-[1.02] tracking-tight mb-5 dark:text-white hero-item"
          style="--delay: 0.06s; font-variation-settings: 'opsz' 144;"
          set:html={title}
        />
      )}

      <!-- Accent rule -->
      {title && (
        <div class="w-14 h-[3px] rounded-full mb-8 hero-item" style="--delay: 0.12s; background: var(--aw-color-primary);"></div>
      )}

      <!-- Subtitle -->
      {subtitle && (
        <div class="max-w-xl hero-item" style="--delay: 0.18s">
          <p class="text-lg md:text-xl text-muted leading-relaxed" set:html={subtitle} />
        </div>
      )}

      <!-- CTA buttons -->
      {actions && (
        <div class="flex flex-wrap gap-3 mt-10 hero-item" style="--delay: 0.24s">
          {Array.isArray(actions) ? (
            actions.map((action) => (
              <Button {...(action || {})} />
            ))
          ) : (
            <Fragment set:html={actions} />
          )}
        </div>
      )}

      {content && <Fragment set:html={content} />}
    </div>

    <!-- Optional image -->
    {image && (
      <div class="intersect-once intersect-no-queue intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
        <div class="relative max-w-5xl mx-auto">
          {typeof image === 'string' ? (
            <Fragment set:html={image} />
          ) : (
            <Image
              class="mx-auto rounded-sm w-full"
              widths={[400, 768, 1024, 2040]}
              sizes="(max-width: 767px) 400px, (max-width: 1023px) 768px, (max-width: 2039px) 1024px, 2040px"
              loading="eager"
              width={1024}
              height={576}
              {...image}
            />
          )}
        </div>
      </div>
    )}
  </div>
</section>

<style>
  /* Staggered entrance for hero elements */
  .hero-item {
    animation: heroRise 0.9s cubic-bezier(0.22, 1, 0.36, 1) var(--delay, 0s) both;
  }

  @keyframes heroRise {
    from {
      opacity: 0;
      transform: translateY(1.25rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-item {
      animation: none;
    }
  }

  /* Faint dot-grid pattern: visible but unobtrusive */
  .hero-grid {
    background-image: radial-gradient(circle, rgb(249 115 22 / 0.12) 1px, transparent 1px);
    background-size: 40px 40px;
    mask-image: radial-gradient(ellipse 80% 80% at 10% 50%, black 20%, transparent 100%);
  }

  .dark .hero-grid {
    background-image: radial-gradient(circle, rgb(251 146 60 / 0.1) 1px, transparent 1px);
  }
</style>
