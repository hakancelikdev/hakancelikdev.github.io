---
import { Icon } from 'astro-icon/components';
import type { Post } from '~/types';
import { getPermalink } from '~/utils/permalinks';

export interface Props {
  post: Post;
  seriesPosts: Post[];
}

const { post, seriesPosts } = Astro.props;
---

<div class="mx-auto max-w-3xl px-4 sm:px-6 mb-8">
  <div class="rounded-xl border dark:border-slate-700 overflow-hidden">
    <div class="px-4 py-3 bg-gray-50 dark:bg-slate-800/60 flex items-center gap-2 border-b dark:border-slate-700">
      <Icon name="tabler:list-numbers" class="w-4 h-4 text-primary flex-shrink-0" />
      <span class="text-sm font-semibold">Seri: {post.series}</span>
      <span class="ml-auto text-xs text-muted dark:text-slate-500">{seriesPosts.length} yazı</span>
    </div>
    <ol class="divide-y dark:divide-slate-700/60">
      {
        seriesPosts.map((p) => {
          const isCurrent = p.slug === post.slug;
          return (
            <li
              class={`flex items-start gap-3 px-4 py-3 ${isCurrent ? 'bg-primary/5 dark:bg-primary/10' : 'hover:bg-gray-50 dark:hover:bg-slate-800/30 transition-colors'}`}
            >
              <span
                class={`text-xs font-mono w-5 flex-shrink-0 mt-0.5 font-bold ${isCurrent ? 'text-primary' : 'text-muted dark:text-slate-500'}`}
              >
                {p.seriesIndex ?? '?'}.
              </span>
              {isCurrent ? (
                <span class="text-sm font-semibold text-primary dark:text-blue-400 leading-snug">{p.title}</span>
              ) : (
                <a
                  href={getPermalink(p.permalink, 'post')}
                  class="text-sm leading-snug hover:text-primary dark:hover:text-blue-400 transition-colors"
                >
                  {p.title}
                </a>
              )}
            </li>
          );
        })
      }
    </ol>
  </div>
</div>
