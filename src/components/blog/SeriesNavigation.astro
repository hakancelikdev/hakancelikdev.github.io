---
import { Icon } from 'astro-icon/components';
import type { Post } from '~/types';
import { getPermalink } from '~/utils/permalinks';

export interface Props {
  post: Post;
  seriesPosts: Post[];
}

const { post, seriesPosts } = Astro.props;
const currentIndex = seriesPosts.findIndex((p) => p.slug === post.slug);
const currentNumber = currentIndex >= 0 ? currentIndex + 1 : '?';
---

<div class="mx-auto max-w-3xl px-4 sm:px-6 mb-8">
  <details class="rounded-xl border dark:border-stone-700 overflow-hidden group">
    <summary
      class="px-4 py-3 bg-gray-50 dark:bg-stone-800/60 flex items-center gap-2 cursor-pointer select-none list-none [&::-webkit-details-marker]:hidden hover:bg-gray-100 dark:hover:bg-stone-800 transition-colors"
    >
      <Icon name="tabler:list-numbers" class="w-4 h-4 text-primary flex-shrink-0" />
      <span class="text-sm font-semibold">{post.series}</span>
      <span class="ml-auto flex items-center gap-2 text-xs text-muted dark:text-stone-500">
        <span class="font-medium text-primary">{currentNumber}/{seriesPosts.length}</span>
        <Icon
          name="tabler:chevron-down"
          class="w-4 h-4 transition-transform duration-200 group-open:rotate-180"
        />
      </span>
    </summary>

    <ol class="divide-y dark:divide-stone-700/60">
      {
        seriesPosts.map((p) => {
          const isCurrent = p.slug === post.slug;
          return (
            <li
              class={`flex items-start gap-3 px-4 py-3 ${isCurrent ? 'bg-primary/5 dark:bg-primary/10' : 'hover:bg-gray-50 dark:hover:bg-stone-800/30 transition-colors'}`}
            >
              <span
                class={`text-xs font-mono w-5 flex-shrink-0 mt-0.5 font-bold ${isCurrent ? 'text-primary' : 'text-muted dark:text-stone-500'}`}
              >
                {p.seriesIndex ?? '?'}.
              </span>
              {isCurrent ? (
                <span class="text-sm font-semibold text-primary dark:text-primary leading-snug">{p.title}</span>
              ) : (
                <a
                  href={getPermalink(p.permalink, 'post')}
                  class="text-sm leading-snug hover:text-primary dark:hover:text-blue-400 transition-colors"
                >
                  {p.title}
                </a>
              )}
            </li>
          );
        })
      }
    </ol>
  </details>
</div>
