---
import Layout from '~/layouts/PageLayout.astro';
import JsonLd from '~/components/common/JsonLd.astro';

import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getPermalink } from '~/utils/permalinks';
import profileHeroImg from '~/assets/images/profile-hero.jpg';

import fs from 'node:fs';
import path from 'node:path';

const CACHE_FILE = path.resolve('./src/data/_stats-cache.json');

interface StatsCache {
  fetchedAt: number;
  github: Record<string, string>;
  pypi: Record<string, string>;
}

function readCache(): StatsCache | null {
  try {
    const raw = fs.readFileSync(CACHE_FILE, 'utf-8');
    return JSON.parse(raw) as StatsCache;
  } catch { return null; }
}

function badge(icon: string, value: string, title: string) {
  if (!value || value === '0') return '';
  return `<span title="${title}" class="inline-flex items-center gap-1 text-xs font-medium bg-orange-50 dark:bg-orange-950/30 text-orange-700 dark:text-orange-300 px-2 py-0.5 rounded-sm">${icon} ${value}</span>`;
}

function statsBadges(stars: string, downloads: string) {
  const b = [badge('★', stars, 'GitHub Stars'), badge('↓', downloads, 'PyPI Downloads')]
    .filter(Boolean).join(' ');
  return b ? `<span class="flex gap-1.5 mt-2 flex-wrap">${b}</span>` : '';
}

const cached = readCache();

const unimportStars  = cached?.github['unimportStars']   ?? '';
const unexportStars  = cached?.github['unexportStars']   ?? '';
const pydbmStars     = cached?.github['pydbmStars']      ?? '';
const defineifStars  = cached?.github['defineifStars']   ?? '';
const vakitStars     = cached?.github['vakitStars']      ?? '';
const siteSeekerStars = cached?.github['siteSeekerStars'] ?? '';
const meldStars      = cached?.github['meldStars']       ?? '';
const unimportDl     = cached?.pypi['unimport']          ?? '';
const unexportDl     = cached?.pypi['unexport']          ?? '';
const pydbmDl        = cached?.pypi['pythonic-dbm']      ?? '';
const defineifDl     = cached?.pypi['defineif']          ?? '';

const metadata = {
  title: 'Hakan Çelik — Software Engineer',
  ignoreTitleTemplate: true,
  description: 'Hakan Çelik — Software Engineer. Python tools, iOS/macOS apps, and open source software blog.',
  keywords: 'Hakan Celik, Python, software engineer, open source, unimport, unexport, pydbm, iOS, macOS, Django, Go, Trendyol',
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Hakan Çelik',
  url: 'https://hakancelik.dev/en',
  description: metadata.description,
  inLanguage: 'en-US',
  author: {
    '@type': 'Person',
    name: 'Hakan Çelik',
    url: 'https://hakancelik.dev',
  },
};

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Hakan Çelik',
  url: 'https://hakancelik.dev',
  jobTitle: 'Software Engineer',
  worksFor: {
    '@type': 'Organization',
    name: 'Trendyol Go',
  },
  sameAs: [
    'https://twitter.com/hakancelikdev',
    'https://github.com/hakancelikdev',
    'https://www.linkedin.com/in/hakancelikdev',
  ],
};
---

<Layout metadata={metadata}>
  <Fragment slot="head">
    <JsonLd schema={[websiteSchema, personSchema]} />
  </Fragment>

  <!-- Hero: Split layout -->
  <section id="hero" class="relative not-prose md:-mt-[76px] overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_70%_at_-5%_50%,rgb(234_88_12/0.07),transparent)] dark:bg-[radial-gradient(ellipse_80%_70%_at_-5%_50%,rgb(251_146_60/0.08),transparent)]"></div>
    </div>
    <div class="pt-0 md:pt-[76px]"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-0 lg:gap-16 items-center py-16 md:py-24 lg:py-32">
        <div class="order-2 lg:order-1 hero-item" style="--delay: 0.1s">
          <div class="mb-10">
            <span class="inline-flex items-center gap-3 font-mono text-[10px] tracking-[0.2em] uppercase text-primary border-l-2 border-primary bg-primary/[0.04] px-4 py-2">
              <span class="w-1.5 h-1.5 rounded-full bg-primary inline-block shrink-0 animate-pulse"></span>
              Software Engineer & Open Source Enthusiast
            </span>
          </div>
          <h1
            class="font-heading text-5xl sm:text-6xl md:text-7xl lg:text-[5.5rem] font-bold leading-[0.95] tracking-tighter mb-8 dark:text-white"
            style="font-variation-settings: 'opsz' 144, 'wght' 800;"
          >
            Hi, I'm <span class="text-accent dark:text-white">Hakan Çelik</span>
          </h1>
          <div class="w-16 h-0.5 bg-primary/40 mb-8"></div>
          <p class="text-xl md:text-2xl text-muted leading-relaxed font-light italic mb-10 max-w-lg" style="font-family: var(--aw-font-serif);">
            <span class="font-semibold">Software Engineer</span> — Python tooling, iOS/macOS apps, and open source.
            Working at Trendyol Go by Uber Eats since 2019.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="#projects" class="btn btn-primary rounded-none border-2 hover:bg-primary hover:text-white transition-all duration-300 inline-flex items-center gap-2">View Projects</a>
            <a href={getPermalink('/en/blog')} class="btn rounded-none border-2 hover:bg-primary hover:text-white transition-all duration-300">Blog</a>
          </div>
        </div>
        <div class="order-1 lg:order-2 mb-12 lg:mb-0 hero-item" style="--delay: 0.3s">
          <div class="relative">
            <div class="absolute -inset-3 border-2 border-primary/10 -z-10 hidden lg:block"></div>
            <div class="absolute -inset-6 border border-primary/5 -z-20 hidden lg:block"></div>
            <img src={profileHeroImg.src} alt="Hakan Çelik" width="1920" height="1440" class="w-full shadow-2xl shadow-primary/10" loading="eager" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <Features2
    id="projects"
    title="Apps"
    subtitle="Applications I've built for iOS and macOS."
    tagline="Apps"
    items={[
      {
        title: 'Vakit',
        description: `Prayer times, Quran reading, Qibla finder, Dhikr counter and more — all in one app. Privacy-first: your location stays on-device, no account required, works fully offline. Free and ad-free.${statsBadges(vakitStars, '')} <br /><br />
        <a href="https://apps.apple.com/app/id6748356813" target="_blank" class="text-primary hover:underline">Download (App Store)</a>`,
        icon: 'tabler:moon-stars',
        callToAction: { text: 'vakit.hakancelik.dev', href: 'https://vakit.hakancelik.dev', target: '_blank' },
      },
      {
        title: 'SiteSeeker',
        description: `Smart browser history and bookmark search for macOS. Search all your browsers in one interface.${statsBadges(siteSeekerStars, '')} <br /><br />
        <a href="https://github.com/hakancelikdev/SiteSeeker" target="_blank" class="text-primary hover:underline">Star on GitHub</a>`,
        icon: 'tabler:search',
        callToAction: { text: 'siteseeker.hakancelik.dev', href: 'https://siteseeker.hakancelik.dev', target: '_blank' },
      },
      {
        title: 'Meld',
        description: `Minimalist tile-merging puzzle game. Slide, merge, solve.${statsBadges(meldStars, '')}`,
        icon: 'tabler:puzzle',
        callToAction: { text: 'meld.hakancelik.dev', href: 'https://meld.hakancelik.dev', target: '_blank' },
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-orange-50/30 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <Features3
    title="Python Tools"
    subtitle="Open source tools that improve the Python developer experience."
    tagline="Open Source"
    columns={2}
    items={[
      {
        title: 'unimport',
        description: `A linter/formatter that finds and removes unused import statements. Works as a pre-commit hook.${statsBadges(unimportStars, unimportDl)} <br /><br />
        <a href="https://github.com/hakancelikdev/unimport" target="_blank" class="text-primary hover:underline">Star on GitHub</a>`,
        icon: 'tabler:brand-python',
        callToAction: { text: 'unimport.hakancelik.dev', href: 'https://unimport.hakancelik.dev', target: '_blank' },
      },
      {
        title: 'unexport',
        description: `A linter that keeps the __all__ list in Python modules always up to date.${statsBadges(unexportStars, unexportDl)} <br /><br />
        <a href="https://github.com/hakancelikdev/unexport" target="_blank" class="text-primary hover:underline">Star on GitHub</a>`,
        icon: 'tabler:brand-python',
        callToAction: { text: 'unexport.hakancelik.dev', href: 'https://unexport.hakancelik.dev', target: '_blank' },
      },
      {
        title: 'pydbm',
        description: `A Pythonic ORM-like wrapper around Python's built-in dbm module.${statsBadges(pydbmStars, pydbmDl)} <br /><br />
        <a href="https://github.com/hakancelikdev/pydbm" target="_blank" class="text-primary hover:underline">Star on GitHub</a>`,
        icon: 'tabler:database',
        callToAction: { text: 'pydbm.hakancelik.dev', href: 'https://pydbm.hakancelik.dev', target: '_blank' },
      },
      {
        title: 'defineif',
        description: `A decorator that defines a method only when a condition is true. Simple but elegant.${statsBadges(defineifStars, defineifDl)} <br /><br />
        <a href="https://github.com/hakancelikdev/defineif" target="_blank" class="text-primary hover:underline">Star on GitHub</a>`,
        icon: 'tabler:code',
        callToAction: { text: 'defineif.hakancelik.dev', href: 'https://defineif.hakancelik.dev', target: '_blank' },
      },
    ]}
  />

  <BlogLatestPosts
    id="blog"
    title="Latest Posts"
    information="Articles on Python, Django, Git, OpenCV, Cloud and more."
    lang="en"
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-orange-50/30 dark:bg-transparent"></div>
    </Fragment>
  </BlogLatestPosts>

  <CallToAction
    title="Let's connect on X, LinkedIn, and GitHub"
    subtitle="Follow for new projects, technical notes, and open source updates."
    actions={[
      {
        variant: 'primary',
        text: 'github.com/hakancelikdev',
        href: 'https://github.com/hakancelikdev',
        target: '_blank',
        icon: 'tabler:brand-github',
      },
      {
        text: 'x.com/hakancelikdev',
        href: 'https://twitter.com/hakancelikdev',
        target: '_blank',
        icon: 'tabler:brand-x',
      },
      {
        text: 'linkedin.com/in/hakancelikdev',
        href: 'https://www.linkedin.com/in/hakancelikdev',
        target: '_blank',
        icon: 'tabler:brand-linkedin',
      },
    ]}
  />
</Layout>

<style>
  .hero-item {
    animation: heroRise 1.2s cubic-bezier(0.16, 1, 0.3, 1) var(--delay, 0s) both;
  }
  @keyframes heroRise {
    from { opacity: 0; transform: translateY(2rem); }
    to { opacity: 1; transform: translateY(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-item { animation: none; }
  }
</style>
