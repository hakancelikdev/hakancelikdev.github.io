---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getPermalink } from '~/utils/permalinks';

// Build-time stats helpers
import fs from 'node:fs';
import path from 'node:path';

const sleep = (ms: number) => new Promise((r) => setTimeout(r, ms));

// Cache file: stores fetched stats for 1 hour to avoid rate-limiting pypistats in dev mode
const CACHE_FILE = path.resolve('./src/data/_stats-cache.json');
const CACHE_TTL_MS = 60 * 60 * 1000; // 1 hour

interface StatsCache {
  fetchedAt: number;
  github: Record<string, string>;
  pypi: Record<string, string>;
}

function readCache(): StatsCache | null {
  try {
    const raw = fs.readFileSync(CACHE_FILE, 'utf-8');
    const cache: StatsCache = JSON.parse(raw);
    if (Date.now() - cache.fetchedAt < CACHE_TTL_MS) return cache;
  } catch { /* no cache or invalid */ }
  return null;
}

function writeCache(cache: StatsCache) {
  try { fs.writeFileSync(CACHE_FILE, JSON.stringify(cache, null, 2)); } catch { /* ignore write errors */ }
}

async function githubStars(repo: string): Promise<string> {
  try {
    const res = await fetch(`https://api.github.com/repos/${repo}`, {
      headers: { Accept: 'application/vnd.github.v3+json' },
    });
    if (!res.ok) return '';
    const data = await res.json();
    const n: number = data.stargazers_count;
    return n >= 1000 ? `${(n / 1000).toFixed(1)}k` : String(n);
  } catch {
    return '';
  }
}

async function pypiDownloads(pkg: string): Promise<string> {
  for (let attempt = 0; attempt < 3; attempt++) {
    try {
      if (attempt > 0) await sleep(3000 * attempt);
      const res = await fetch(`https://pypistats.org/api/packages/${pkg}/recent?period=month`);
      if (res.status === 429) continue;
      if (!res.ok) return '';
      const data = await res.json();
      const n: number = data.data.last_month;
      if (n >= 1_000_000) return `${(n / 1_000_000).toFixed(1)}M/ay`;
      if (n >= 1_000) return `${Math.round(n / 1000)}k/ay`;
      return `${n}/ay`;
    } catch {
      return '';
    }
  }
  return '';
}

function badge(icon: string, value: string, title: string) {
  if (!value || value === '0') return '';
  return `<span title="${title}" class="inline-flex items-center gap-1 text-xs font-medium bg-orange-50 dark:bg-orange-950/30 text-orange-700 dark:text-orange-300 px-2 py-0.5 rounded-sm">${icon} ${value}</span>`;
}

function statsBadges(stars: string, downloads: string) {
  const b = [badge('★', stars, 'GitHub Stars'), badge('↓', downloads, 'PyPI Downloads')]
    .filter(Boolean)
    .join(' ');
  return b ? `<span class="flex gap-1.5 mt-2 flex-wrap">${b}</span>` : '';
}

// Check cache first — avoids hitting rate limits during dev reloads
const cached = readCache();

let unimportStars: string, unexportStars: string, pydbmStars: string, defineifStars: string;
let vakitStars: string, siteSeekerStars: string, meldStars: string;
let unimportDl: string, unexportDl: string, pydbmDl: string, defineifDl: string;

if (cached) {
  ({ unimportStars = '', unexportStars = '', pydbmStars = '', defineifStars = '',
     vakitStars = '', siteSeekerStars = '', meldStars = '' } = cached.github as Record<string, string>);
  unimportDl  = cached.pypi['unimport']      ?? '';
  unexportDl  = cached.pypi['unexport']      ?? '';
  pydbmDl     = cached.pypi['pythonic-dbm']  ?? '';
  defineifDl  = cached.pypi['defineif']      ?? '';
} else {
  // GitHub: parallel (different host, no rate limit issue)
  [unimportStars, unexportStars, pydbmStars, defineifStars,
   vakitStars, siteSeekerStars, meldStars] = await Promise.all([
    githubStars('hakancelikdev/unimport'),
    githubStars('hakancelikdev/unexport'),
    githubStars('hakancelikdev/pydbm'),
    githubStars('hakancelikdev/defineif'),
    githubStars('hakancelikdev/vakit'),
    githubStars('hakancelikdev/SiteSeeker'),
    githubStars('hakancelikdev/meld'),
  ]);

  // PyPI: sequential with delay to avoid 429 (rate limit: ~3 req/10s per IP)
  unimportDl  = await pypiDownloads('unimport');        await sleep(4000);
  unexportDl  = await pypiDownloads('unexport');        await sleep(4000);
  pydbmDl     = await pypiDownloads('pythonic-dbm');    await sleep(4000);
  defineifDl  = await pypiDownloads('defineif');

  writeCache({
    fetchedAt: Date.now(),
    github: { unimportStars, unexportStars, pydbmStars, defineifStars,
              vakitStars, siteSeekerStars, meldStars },
    pypi: { unimport: unimportDl, unexport: unexportDl, 'pythonic-dbm': pydbmDl, defineif: defineifDl },
  });
}

const metadata = {
  title: 'Hakan Çelik — Software Engineer',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>

  <!-- Hero -->
  <Hero
    id="hero"
    actions={[
      { variant: 'primary', text: 'Projeleri Gör', href: '#projects', icon: 'tabler:rocket' },
      { text: 'Blog', href: getPermalink('/blog') },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_70%_at_-5%_50%,rgb(234_88_12/0.07),transparent)] dark:bg-[radial-gradient(ellipse_80%_70%_at_-5%_50%,rgb(251_146_60/0.08),transparent)]"></div>
    </Fragment>
    <Fragment slot="title">
      Merhaba, ben <span class="text-accent dark:text-white">Hakan Çelik</span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="font-semibold">Software Engineer</span> — Python tooling · iOS/macOS apps · Open source.
      Trendyol Go by Uber Eats'te yazılım geliştirici olarak çalışıyorum. 2019'dan beri profesyonel olarak yazılım geliştiriyorum.
    </Fragment>
  </Hero>

  <!-- Uygulamalar -->
  <Features2
    id="projects"
    title="Uygulamalar"
    subtitle="iOS ve macOS için geliştirdiğim uygulamalar."
    tagline="Apps"
    items={[
      {
        title: 'Vakit',
        description: `Namaz vakti hatırlatıcınız ve kıble. iOS için minimalist, kullanımı kolay bir uygulama.${statsBadges(vakitStars, '')}`,
        icon: 'tabler:moon-stars',
        callToAction: { text: 'vakit.hakancelik.dev', href: 'https://vakit.hakancelik.dev', target: '_blank' },
      },
      {
        title: 'SiteSeeker',
        description: `macOS için akıllı tarayıcı geçmişi ve yer imi arama. Tüm tarayıcılarını tek arayüzde ara.${statsBadges(siteSeekerStars, '')}`,
        icon: 'tabler:search',
        callToAction: { text: 'siteseeker.hakancelik.dev', href: 'https://siteseeker.hakancelik.dev', target: '_blank' },
      },
      {
        title: 'Meld',
        description: `Minimalist karo birleştirme bulmaca oyunu. Kaydır, birleştir, çöz.${statsBadges(meldStars, '')}`,
        icon: 'tabler:puzzle',
        callToAction: { text: 'meld.hakancelik.dev', href: 'https://meld.hakancelik.dev', target: '_blank' },
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-indigo-50/50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- Python Araçları -->
  <Features3
    title="Python Araçları"
    subtitle="Python geliştirici deneyimini iyileştiren açık kaynak araçlar."
    tagline="Open Source"
    columns={2}
    items={[
      {
        title: 'unimport',
        description: `Kullanılmayan import ifadelerini bulan ve kaldıran linter/formatter. pre-commit hook olarak kullanılabilir.${statsBadges(unimportStars, unimportDl)}`,
        icon: 'tabler:brand-python',
        callToAction: { text: 'unimport.hakancelik.dev', href: 'https://unimport.hakancelik.dev', target: '_blank' },
      },
      {
        title: 'unexport',
        description: `Python modüllerindeki __all__ listesini her zaman güncel tutan linter.${statsBadges(unexportStars, unexportDl)}`,
        icon: 'tabler:brand-python',
        callToAction: { text: 'unexport.hakancelik.dev', href: 'https://unexport.hakancelik.dev', target: '_blank' },
      },
      {
        title: 'pydbm',
        description: `Python'ın dahili dbm modülünü ORM benzeri bir arayüzle kullanan Pythonic wrapper.${statsBadges(pydbmStars, pydbmDl)}`,
        icon: 'tabler:database',
        callToAction: { text: 'pydbm.hakancelik.dev', href: 'https://pydbm.hakancelik.dev', target: '_blank' },
      },
      {
        title: 'defineif',
        description: `Bir koşul doğruysa metodu tanımla decorator'u. Basit ama zarif.${statsBadges(defineifStars, defineifDl)}`,
        icon: 'tabler:code',
        callToAction: { text: 'defineif.hakancelik.dev', href: 'https://defineif.hakancelik.dev', target: '_blank' },
      },
    ]}
  />

  <!-- Blog -->
  <BlogLatestPosts
    id="blog"
    title="Son Yazılar"
    information="Python, Django, Git, OpenCV, Cloud ve daha fazlası üzerine Türkçe yazılar."
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-indigo-50/50 dark:bg-transparent"></div>
    </Fragment>
  </BlogLatestPosts>

  <!-- CTA -->
  <CallToAction
    title="GitHub'da takip et"
    subtitle="Açık kaynak projelerime katkıda bulunabilir veya ilham alabilirsin."
    actions={[
      {
        variant: 'primary',
        text: 'github.com/hakancelikdev',
        href: 'https://github.com/hakancelikdev',
        target: '_blank',
        icon: 'tabler:brand-github',
      },
    ]}
  />
</Layout>
