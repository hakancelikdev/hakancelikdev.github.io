---
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..700;1,9..144,300..700&family=Epilogue:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
  rel="stylesheet"
/>

<style is:inline>
  :root {
    --aw-font-sans: 'Epilogue', ui-sans-serif;
    --aw-font-serif: 'Fraunces', ui-serif;
    --aw-font-heading: 'Fraunces', ui-serif;

    /* Warm orange accent */
    --aw-color-primary: rgb(234 88 12);
    --aw-color-secondary: rgb(194 65 12);
    --aw-color-accent: rgb(249 115 22);

    /* Light mode — warm cream */
    --aw-color-text-heading: rgb(28 25 23);
    --aw-color-text-default: rgb(41 37 36);
    --aw-color-text-muted: rgb(41 37 36 / 58%);
    --aw-color-bg-page: rgb(250 247 242);
    --aw-color-bg-page-dark: rgb(12 10 8);

    ::selection {
      background-color: rgb(254 215 170);
      color: rgb(124 45 18);
    }
  }

  .dark {
    --aw-font-sans: 'Epilogue', ui-sans-serif;
    --aw-font-serif: 'Fraunces', ui-serif;
    --aw-font-heading: 'Fraunces', ui-serif;

    /* Lighter orange for dark bg */
    --aw-color-primary: rgb(251 146 60);
    --aw-color-secondary: rgb(249 115 22);
    --aw-color-accent: rgb(251 146 60);

    /* Dark mode — warm near-black */
    --aw-color-text-heading: rgb(250 247 242);
    --aw-color-text-default: rgb(214 211 208);
    --aw-color-text-muted: rgb(214 211 208 / 58%);
    --aw-color-bg-page: rgb(12 10 8);

    ::selection {
      background-color: rgb(124 45 18);
      color: rgb(254 215 170);
    }
  }
</style>
